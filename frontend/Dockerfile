# BallotBuddy Frontend – Dockerfile
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci --legacy-peer-deps
COPY . .

# Build Arguments
ARG VITE_API_URL
ARG VITE_GCP_PROJECT_ID
ARG VITE_GCP_API_KEY
ARG VITE_GCP_MESSAGING_SENDER_ID
ARG VITE_GCP_APP_ID
ARG VITE_GCP_VAPID_KEY
ARG VITE_GA_MEASUREMENT_ID

# Map Args to Envs for Vite
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_GCP_PROJECT_ID=$VITE_GCP_PROJECT_ID
ENV VITE_GCP_API_KEY=$VITE_GCP_API_KEY
ENV VITE_GCP_MESSAGING_SENDER_ID=$VITE_GCP_MESSAGING_SENDER_ID
ENV VITE_GCP_APP_ID=$VITE_GCP_APP_ID
ENV VITE_GCP_VAPID_KEY=$VITE_GCP_VAPID_KEY
ENV VITE_GA_MEASUREMENT_ID=$VITE_GA_MEASUREMENT_ID

RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
